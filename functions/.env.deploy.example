# ============================================================
# Firebase Functions Environment Variables
# ============================================================
# 1. Copy this file:  cp functions/.env.deploy.example functions/.env.deploy
# 2. Fill in all values below
# 3. Deploy:          bash functions/deploy.sh
# ============================================================

# Twilio (find in Twilio Console → Account Info)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=

# Live mode (חי) — real emergency
LIVE_CONTENT_SID=
LIVE_SHEET_ID=
LIVE_SHEET_NAME=2025

# Drill mode (תרגיל) — drill exercise
DRILL_CONTENT_SID=
DRILL_SHEET_ID=
DRILL_SHEET_NAME=2025

# Load test (any string you choose — used as ?key= in seed/clear endpoints)
LOADTEST_SECRET=
